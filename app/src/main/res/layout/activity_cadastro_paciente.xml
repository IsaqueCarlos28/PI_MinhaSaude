<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:background="@drawable/bg_login_card"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="40dp">

        <!-- Botão Voltar -->
        <TextView
            android:id="@+id/btnVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@drawable/ic_arrow_back"
            android:drawablePadding="4dp"
            android:drawableTint="#3B82F6"
            android:fontFamily="sans-serif-medium"
            android:text="Voltar"
            android:textColor="#3B82F6"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Título -->
        <TextView
            android:id="@+id/tvTituloCadastro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Cadastrar-se"
            android:textColor="#1A1A2E"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnVoltar" />

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/tvSubtituloCadastro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Sua saúde a um clique de distância. Cadastre-se em segundos."
            android:textColor="#6B7280"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTituloCadastro" />

        <!-- Campo: Usuário -->
        <EditText
            android:id="@+id/etUsuario"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_input_field"
            android:drawableStart="@drawable/ic_user"
            android:drawablePadding="16dp"
            android:drawableTint="#60A5FA"
            android:hint="Usuário"
            android:inputType="textPersonName"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtituloCadastro" />

        <!-- Campo: CPF -->
        <EditText
            android:id="@+id/etCpf"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:drawableStart="@drawable/ic_cpf"
            android:drawablePadding="16dp"
            android:drawableTint="#60A5FA"
            android:hint="CPF"
            android:inputType="number"
            android:maxLength="14"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etUsuario" />

        <!-- Campo: E-mail -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:drawableStart="@drawable/ic_email"
            android:drawablePadding="16dp"
            android:drawableTint="#60A5FA"
            android:hint="E-mail"
            android:inputType="textEmailAddress"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etCpf" />

        <!-- Campo: Telefone -->
        <EditText
            android:id="@+id/etTelefone"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:drawablePadding="16dp"
            android:drawableTint="#60A5FA"
            android:hint="Telefone"
            android:inputType="phone"
            android:maxLength="15"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etEmail" />

        <EditText
            android:id="@+id/etGenero"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:drawableStart="@drawable/ic_genero"
            android:drawablePadding="16dp"
            android:drawableTint="#60A5FA"
            android:hint="Gênero"
            android:inputType="textCapWords"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etTelefone" />

        <!-- Campo: Data de Nascimento -->
        <EditText
            android:id="@+id/etDataNascimento"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:drawableStart="@drawable/ic_calendar"
            android:drawablePadding="16dp"
            android:drawableTint="#60A5FA"
            android:hint="Data de Nascimento (DD-MM-AAAA)"
            android:inputType="text"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etGenero" />

        <!-- Campo: Senha -->
        <EditText
            android:id="@+id/etSenha"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:drawableStart="@drawable/ic_password"
            android:drawablePadding="16dp"
            android:drawableTint="#60A5FA"
            android:hint="Senha"
            android:inputType="textPassword"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etDataNascimento" />

        <!-- Campo: Confirmar Senha -->
        <EditText
            android:id="@+id/etConfirmarSenha"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:drawableStart="@drawable/ic_password"
            android:drawablePadding="16dp"
            android:drawableTint="#60A5FA"
            android:hint="Confirmar Senha"
            android:inputType="textPassword"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:textColor="#000000"
            android:textColorHint="#9E9E9E"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etSenha" />

        <!-- Botão Cadastrar -->
        <Button
            android:id="@+id/btnCadastrar"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="#3B82F6"
            android:text="Cadastrar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etConfirmarSenha" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>