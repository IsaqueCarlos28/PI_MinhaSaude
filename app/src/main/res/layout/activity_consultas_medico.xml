<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background_gradient"
        android:paddingTop="40dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="20dp">

        <ImageView
            android:id="@+id/imgAvatarConsultas"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:src="@drawable/ic_user"
            android:background="#4D6EAB"
            android:padding="6dp" />

        <TextView
            android:id="@+id/tvSaudacaoConsultas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/imgAvatarConsultas"
            android:layout_alignTop="@id/imgAvatarConsultas"
            android:layout_marginStart="10dp"
            android:text="Olá, Médico"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Consultas"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- FILTRO STATUS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="12dp"
        android:background="#FFFFFF"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFiltroTodas"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="#3B82F6"
                android:text="Todas"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnFiltroAgendadas"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="#94A3B8"
                android:text="Agendadas"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnFiltroRealizadas"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="#94A3B8"
                android:text="Realizadas"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnFiltroCanceladas"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="#94A3B8"
                android:text="Canceladas"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- LISTA DE CONSULTAS (com estado vazio) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvConsultasMedico"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false" />

        <TextView
            android:id="@+id/tvConsultasMedicoVazio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Nenhuma consulta encontrada"
            android:textColor="#94A3B8"
            android:textSize="15sp"
            android:visibility="gone" />

    </FrameLayout>

    <!-- BOTTOM NAVIGATION -->
    <include
        android:id="@+id/bottomNavMedico"
        layout="@layout/view_bottom_nav_medico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
