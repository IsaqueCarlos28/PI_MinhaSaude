<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- HEADER GRADIENTE -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background_gradient"
        android:paddingTop="44dp"
        android:paddingBottom="28dp"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Configurações"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <!-- CONTEÚDO SCROLLÁVEL -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- SEÇÃO: Conta e Perfil -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conta e Perfil"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <!-- ITEM: Perfil do Usuário (com avatar e nome) -->
            <LinearLayout
                android:id="@+id/itemPerfilMedicoUsuario"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_list_item"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <!-- Avatar circular -->
                <ImageView
                    android:id="@+id/imgAvatarMedicoConfig"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_user"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="#3B82F6"
                    android:padding="8dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvNomeMedicoConfig"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Morgana Rodrigues"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSubtitleMedicoConfig"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Infos Perfil"
                        android:textColor="#3B82F6"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ITEM: Segurança -->
            <LinearLayout
                android:id="@+id/itemSegurancaMedico"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_list_item"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_password"
                    android:tint="#64748B" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Segurança (Alterar senha)"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#94A3B8"
                    android:textSize="20sp" />

            </LinearLayout>

            <!-- ITEM: Notificações -->
            <LinearLayout
                android:id="@+id/itemNotificacoesMedico"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_list_item"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="#64748B" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Notificações"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#94A3B8"
                    android:textSize="20sp" />

            </LinearLayout>

            <!-- ITEM: Idioma -->
            <LinearLayout
                android:id="@+id/itemIdiomaMedico"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_list_item"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_email"
                    android:tint="#64748B" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Idioma"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#94A3B8"
                    android:textSize="20sp" />

            </LinearLayout>

            <!-- ITEM: FAQ/Ajuda -->
            <LinearLayout
                android:id="@+id/itemFaqMedico"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_list_item"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_user"
                    android:tint="#64748B" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="FAQ/Ajuda"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#94A3B8"
                    android:textSize="20sp" />

            </LinearLayout>

            <!-- ITEM: Termos de Uso -->
            <LinearLayout
                android:id="@+id/itemTermosMedico"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_list_item"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_cpf"
                    android:tint="#64748B" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Termos de Uso e Privacidade"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#94A3B8"
                    android:textSize="20sp" />

            </LinearLayout>

            <!-- ITEM: Sobre o App -->
            <LinearLayout
                android:id="@+id/itemSobreAppMedico"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_list_item"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    android:tint="#64748B" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Sobre o App"
                    android:textColor="#1E293B"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#94A3B8"
                    android:textSize="20sp" />

            </LinearLayout>

            <!-- BOTÃO ENCERRAR SESSÃO -->
            <Button
                android:id="@+id/btnEncerrarSessaoMedico"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="#3B82F6"
                android:text="Encerrar Sessão"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <include
        layout="@layout/view_bottom_nav_medico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
