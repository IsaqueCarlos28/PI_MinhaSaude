<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- TOPO: botão voltar simples (sem gradiente) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#F0F4F8"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnVoltarPesquisa"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#1E293B"
            android:contentDescription="Voltar" />

    </RelativeLayout>

    <!-- BARRA DE BUSCA: Médico ou Especialidade -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:paddingHorizontal="14dp">

            <ImageView
                android:id="@+id/icBuscaAvancada"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_search"
                android:tint="#64748B" />

            <EditText
                android:id="@+id/etPesquisarMedicoOuEspecialidade"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toEndOf="@id/icBuscaAvancada"
                android:layout_marginStart="10dp"
                android:background="@null"
                android:hint="Pesquisar Médicos ou Especialidades"
                android:textColorHint="#9E9E9E"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

    <!-- BARRA DE BUSCA: Localidade -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:paddingHorizontal="14dp">

            <ImageView
                android:id="@+id/icLocalidade"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_user"
                android:tint="#64748B" />

            <EditText
                android:id="@+id/etPesquisarLocalidade"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toEndOf="@id/icLocalidade"
                android:layout_marginStart="10dp"
                android:background="@null"
                android:hint="Pesquise Localidade"
                android:textColorHint="#9E9E9E"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:inputType="text"
                android:maxLines="1" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

    <!-- FILTROS Presencial / Telemedicina -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnFiltroParticular"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="#3B82F6"
            android:text="Presencial"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp" />

        <Button
            android:id="@+id/btnFiltroConvenio"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/button_border"
            android:text="Telemedicina"
            android:textAllCaps="false"
            android:textColor="#1E293B"
            android:textSize="13sp"
            android:paddingHorizontal="16dp" />

    </LinearLayout>

    <!-- LABEL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"
        android:text="Médicos disponíveis"
        android:textColor="#1E293B"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- LISTA DE RESULTADOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResultadosPesquisa"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- BOTTOM NAVIGATION -->
    <include
        layout="@layout/view_bottom_nav_paciente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
