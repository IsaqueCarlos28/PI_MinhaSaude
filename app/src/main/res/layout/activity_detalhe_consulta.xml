<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background_gradient"
        android:padding="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="20dp">

        <ImageButton
            android:id="@+id/btnVoltarDetalhe"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Voltar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Detalhe da Consulta"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD INFORMAÇÕES -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Médico -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Médico"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tvDetalheMedico"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#1E293B"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginBottom="16dp"/>

                    <!-- Data -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tvDetalheData"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Horário -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Horário"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tvDetalheHora"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Convênio -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Convênio"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tvDetalheConvenio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        android:layout_marginBottom="16dp" />

                    <!-- Status -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginBottom="2dp" />
                    <TextView
                        android:id="@+id/tvDetalheStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#1E293B"
                        android:textSize="15sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- BOTÃO REAGENDAR -->
            <Button
                android:id="@+id/btnReagendarDetalhe"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="#3B82F6"
                android:text="Reagendar Consulta"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- BOTÃO CANCELAR -->
            <Button
                android:id="@+id/btnCancelarDetalhe"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/button_border"
                android:text="Cancelar Consulta"
                android:textAllCaps="false"
                android:textColor="#EF4444"
                android:textSize="15sp"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <include
        layout="@layout/view_bottom_nav_paciente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
