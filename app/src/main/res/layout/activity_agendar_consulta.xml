<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background_gradient"
        android:padding="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Agendar Consulta"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD MÉDICO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/imgMedicoAgendar"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_doctor"
                        android:background="@drawable/bg_button_primary"
                        android:backgroundTint="#E8F0FF"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvNomeMedicoAgendar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Médico"
                        android:textColor="#1E293B"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tvEspecialidadeAgendar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text=""
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/tvCrmAgendar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text=""
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:gravity="center" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- SELETOR DE DATAS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp">

                        <ImageButton
                            android:id="@+id/btnDataAnterior"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_back"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:tint="#3B82F6"
                            android:contentDescription="Data anterior" />

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@+id/btnDataAnterior"
                            android:layout_toStartOf="@+id/btnProximaData"
                            android:layout_centerVertical="true"
                            android:scrollbars="none">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <LinearLayout android:id="@+id/diaBloco0"
                                    android:layout_width="44dp" android:layout_height="wrap_content"
                                    android:orientation="vertical" android:gravity="center"
                                    android:layout_marginHorizontal="2dp" android:paddingVertical="4dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="SEG" android:textColor="#64748B" android:textSize="10sp"
                                        android:textStyle="bold" android:gravity="center"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="00" android:textColor="#64748B" android:textSize="13sp"
                                        android:gravity="center"/>
                                </LinearLayout>

                                <LinearLayout android:id="@+id/diaBloco1"
                                    android:layout_width="44dp" android:layout_height="wrap_content"
                                    android:orientation="vertical" android:gravity="center"
                                    android:layout_marginHorizontal="2dp" android:paddingVertical="4dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="TER" android:textColor="#64748B" android:textSize="10sp"
                                        android:textStyle="bold" android:gravity="center"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="00" android:textColor="#64748B" android:textSize="13sp"
                                        android:gravity="center"/>
                                </LinearLayout>

                                <LinearLayout android:id="@+id/diaBloco2"
                                    android:layout_width="44dp" android:layout_height="wrap_content"
                                    android:orientation="vertical" android:gravity="center"
                                    android:layout_marginHorizontal="2dp" android:paddingVertical="4dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="QUA" android:textColor="#64748B" android:textSize="10sp"
                                        android:textStyle="bold" android:gravity="center"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="00" android:textColor="#64748B" android:textSize="13sp"
                                        android:gravity="center"/>
                                </LinearLayout>

                                <!-- Dia 3 — selecionado por padrão -->
                                <LinearLayout android:id="@+id/diaBloco3"
                                    android:layout_width="44dp" android:layout_height="wrap_content"
                                    android:orientation="vertical" android:gravity="center"
                                    android:layout_marginHorizontal="2dp"
                                    android:background="@drawable/bg_button_primary"
                                    android:backgroundTint="#3B82F6"
                                    android:paddingVertical="4dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="QUI" android:textColor="#FFFFFF" android:textSize="10sp"
                                        android:textStyle="bold" android:gravity="center"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="00" android:textColor="#FFFFFF" android:textSize="13sp"
                                        android:gravity="center"/>
                                </LinearLayout>

                                <LinearLayout android:id="@+id/diaBloco4"
                                    android:layout_width="44dp" android:layout_height="wrap_content"
                                    android:orientation="vertical" android:gravity="center"
                                    android:layout_marginHorizontal="2dp" android:paddingVertical="4dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="SEX" android:textColor="#64748B" android:textSize="10sp"
                                        android:textStyle="bold" android:gravity="center"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="00" android:textColor="#64748B" android:textSize="13sp"
                                        android:gravity="center"/>
                                </LinearLayout>

                                <LinearLayout android:id="@+id/diaBloco5"
                                    android:layout_width="44dp" android:layout_height="wrap_content"
                                    android:orientation="vertical" android:gravity="center"
                                    android:layout_marginHorizontal="2dp" android:paddingVertical="4dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="SAB" android:textColor="#64748B" android:textSize="10sp"
                                        android:textStyle="bold" android:gravity="center"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="00" android:textColor="#64748B" android:textSize="13sp"
                                        android:gravity="center"/>
                                </LinearLayout>

                                <LinearLayout android:id="@+id/diaBloco6"
                                    android:layout_width="44dp" android:layout_height="wrap_content"
                                    android:orientation="vertical" android:gravity="center"
                                    android:layout_marginHorizontal="2dp" android:paddingVertical="4dp">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="DOM" android:textColor="#64748B" android:textSize="10sp"
                                        android:textStyle="bold" android:gravity="center"/>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                        android:text="00" android:textColor="#64748B" android:textSize="13sp"
                                        android:gravity="center"/>
                                </LinearLayout>

                            </LinearLayout>

                        </HorizontalScrollView>

                        <ImageButton
                            android:id="@+id/btnProximaData"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_forward"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:tint="#3B82F6"
                            android:contentDescription="Próxima data" />

                    </RelativeLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- CARD DE HORÁRIOS DINÂMICOS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:minHeight="80dp">

                    <!-- Título da seção -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Horários disponíveis"
                        android:textColor="#1E293B"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <!-- Loading -->
                    <ProgressBar
                        android:id="@+id/progressHorariosAgendar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:visibility="gone" />

                    <!-- Sem horários disponíveis -->
                    <TextView
                        android:id="@+id/tvHorariosVazioAgendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nenhum horário disponível para esta data."
                        android:textColor="#94A3B8"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingVertical="12dp"
                        android:visibility="gone" />

                    <!-- Erro ao carregar -->
                    <TextView
                        android:id="@+id/tvHorariosErroAgendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Não foi possível carregar os horários. Tente novamente."
                        android:textColor="#EF4444"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:paddingVertical="12dp"
                        android:visibility="gone" />

                    <!-- Container dinâmico — botões gerados pela Activity -->
                    <LinearLayout
                        android:id="@+id/containerHorariosAgendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- BOTÃO CONFIRMAR -->
            <Button
                android:id="@+id/btnConfirmarConsulta"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="#3B82F6"
                android:text="Confirmar Consulta"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVerMaisHorarios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="Voltar"
                android:textColor="#3B82F6"
                android:textSize="13sp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <include
        layout="@layout/view_bottom_nav_paciente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
