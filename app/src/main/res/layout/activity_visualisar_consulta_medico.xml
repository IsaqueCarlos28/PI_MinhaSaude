<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background_gradient"
        android:paddingTop="36dp"
        android:paddingBottom="22dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnVoltarConsultaMedico"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_voltar_button"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#2563EB" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginHorizontal="52dp"
            android:gravity="center"
            android:text="Consulta"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detalhes da Consulta"
                android:textColor="#1E293B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_list_item"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Paciente"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvConsultaMedicoPaciente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Carregando..."
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Médico"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvConsultaMedicoNome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Carregando..."
                    android:textColor="#1E293B"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Data"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvConsultaMedicoData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--/--/----"
                    android:textColor="#1E293B"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Horário"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvConsultaMedicoHora"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="#1E293B"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Convênio"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvConsultaMedicoConvenio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Carregando..."
                    android:textColor="#1E293B"
                    android:textSize="15sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textColor="#64748B"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvConsultaMedicoStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Carregando..."
                    android:textColor="#2563EB"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnRealizarConsultaMedico"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="#2563EB"
                android:text="Marcar como realizada"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnCancelarConsultaMedico"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_button_primary"
                android:backgroundTint="#EF4444"
                android:text="Cancelar consulta"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        layout="@layout/view_bottom_nav_medico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />
</LinearLayout>
