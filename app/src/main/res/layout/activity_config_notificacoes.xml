<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background_gradient"
        android:paddingTop="36dp"
        android:paddingBottom="22dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btnVoltarNotificacoes"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_voltar_button"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#2563EB" />

        <TextView
            android:id="@+id/tvTituloNotificacoes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Notificações"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDescricaoNotificacoes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Escolha quais avisos deseja receber."
            android:textColor="#475569"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <Switch
            android:id="@+id/swNotificacoesGerais"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_list_item"
            android:paddingHorizontal="14dp"
            android:text="Notificações gerais"
            android:textColor="#1E293B"
            android:textSize="14sp" />

        <Switch
            android:id="@+id/swLembretesConsulta"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_list_item"
            android:paddingHorizontal="14dp"
            android:text="Lembretes de consulta"
            android:textColor="#1E293B"
            android:textSize="14sp" />

        <Switch
            android:id="@+id/swAlteracoesAgenda"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_list_item"
            android:paddingHorizontal="14dp"
            android:text="Alterações e cancelamentos"
            android:textColor="#1E293B"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvAvisoNotificacoes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_list_item"
            android:padding="14dp"
            android:text="Preferências salvas neste aparelho. A integração com notificações push pode ser conectada posteriormente ao Firebase/FCM."
            android:textColor="#64748B"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
